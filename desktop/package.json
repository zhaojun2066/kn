{
  "name": "kn",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build:debug": "node -e \"require('fs').copyFileSync('update/update.prod.json','update/update.json')\" && tauri build --debug",
    "tauri:build:prod": "node -e \"require('fs').copyFileSync('update/update.prod.json','update/update.json')\" && tauri build",
    "tauri:build:prod:intel": "node -e \"require('fs').copyFileSync('update/update.prod.json','update/update.json')\" && tauri build --target x86_64-apple-darwin",
    "tauri:build:prod:arm": "node -e \"require('fs').copyFileSync('update/update.prod.json','update/update.json')\" && tauri build --target aarch64-apple-darwin",
    "tauri:build:staging": "node -e \"require('fs').copyFileSync('update/update.staging.json','update/update.json')\" && tauri build --debug"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "cytoscape": "^3.34.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.17.0",
    "marked": "^18.0.5",
    "qrcode": "^1.5.4",
    "react": "^18.3",
    "react-dom": "^18.3",
    "simple-icons": "^16.22.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cytoscape": "^3.21.9",
    "@types/react": "^18.3",
    "@types/react-dom": "^18.3",
    "@vitejs/plugin-react": "^5",
    "autoprefixer": "^10.4",
    "jsdom": "^27.0.1",
    "postcss": "^8.4",
    "tailwindcss": "^3.4",
    "typescript": "^5.5",
    "vite": "^6",
    "vitest": "^3.2.6"
  }
}
