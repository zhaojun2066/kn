{
  "identifier": "default",
  "description": "Default capability",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "profile", "cmd": "profile", "args": true },
        { "name": "python3", "cmd": "python3", "args": true },
        { "name": "python", "cmd": "python", "args": true },
        { "name": "sh", "cmd": "/bin/sh", "args": true },
        { "name": "bash", "cmd": "/bin/bash", "args": true },
        { "name": "zsh", "cmd": "/bin/zsh", "args": true },
        { "name": "brew", "cmd": "/opt/homebrew/bin/brew", "args": true },
        { "name": "brew-intel", "cmd": "/usr/local/bin/brew", "args": true },
        { "name": "apt-get", "cmd": "/usr/bin/apt-get", "args": true },
        { "name": "winget", "cmd": "winget", "args": true },
        { "name": "curl", "cmd": "/usr/bin/curl", "args": true },
        { "name": "shasum", "cmd": "/usr/bin/shasum", "args": true },
        { "name": "cmd", "cmd": "cmd", "args": true },
        { "name": "sha256sum", "cmd": "/usr/bin/sha256sum", "args": true },
        { "name": "certutil", "cmd": "certutil", "args": true },
        { "name": "open", "cmd": "/usr/bin/open", "args": true },
        { "name": "xdg-open", "cmd": "/usr/bin/xdg-open", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "profile", "cmd": "profile", "args": true },
        { "name": "python3", "cmd": "python3", "args": true },
        { "name": "python", "cmd": "python", "args": true },
        { "name": "sh", "cmd": "/bin/sh", "args": true },
        { "name": "bash", "cmd": "/bin/bash", "args": true },
        { "name": "zsh", "cmd": "/bin/zsh", "args": true },
        { "name": "brew", "cmd": "/opt/homebrew/bin/brew", "args": true },
        { "name": "brew-intel", "cmd": "/usr/local/bin/brew", "args": true },
        { "name": "apt-get", "cmd": "/usr/bin/apt-get", "args": true },
        { "name": "winget", "cmd": "winget", "args": true },
        { "name": "curl", "cmd": "/usr/bin/curl", "args": true },
        { "name": "shasum", "cmd": "/usr/bin/shasum", "args": true },
        { "name": "cmd", "cmd": "cmd", "args": true },
        { "name": "sha256sum", "cmd": "/usr/bin/sha256sum", "args": true },
        { "name": "certutil", "cmd": "certutil", "args": true },
        { "name": "open", "cmd": "/usr/bin/open", "args": true },
        { "name": "xdg-open", "cmd": "/usr/bin/xdg-open", "args": true }
      ]
    },
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-write",
    "fs:allow-read",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
